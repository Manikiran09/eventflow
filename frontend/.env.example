# For same-domain deployments behind reverse proxy, keep /api.
# For Vercel (frontend) + Railway (backend), prefer setting VITE_BACKEND_URL,
# or set VITE_API_URL directly to https://your-railway-domain/api.
VITE_API_URL=/api

# Backend public URL for loading uploaded images from /uploads
# Example: https://api.your-domain.com
VITE_BACKEND_URL=http://localhost:5000
