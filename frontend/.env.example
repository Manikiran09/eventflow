# For same-domain deployments behind reverse proxy, set /api.
# For Vercel (frontend) + Railway (backend), set full URL:
# VITE_API_URL=https://your-railway-domain.up.railway.app/api
# Leave empty here to avoid incorrect production default on Vercel.
VITE_API_URL=

# Backend public URL for loading uploaded images from /uploads
# Example for Vercel + Railway: https://your-railway-domain.up.railway.app
VITE_BACKEND_URL=
