NODE_ENV=production
PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/eventflow
JWT_SECRET=replace-with-a-long-random-secret
# Comma-separated list of frontend origins allowed to call backend
# Examples: https://eventflow-gilt.vercel.app,https://*.vercel.app
FRONTEND_URLS=https://your-frontend-domain.vercel.app
